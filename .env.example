# Copy this file to .env and fill in the values before running docker compose.

# PostgreSQL password (used by db, db-migrate, and app services)
DB_PASSWORD=changeme-use-a-strong-password

# rclone remote path for offsite backups (requires the `offsite` profile)
# Example: gdrive:my-bucket/inventory-backups
RCLONE_REMOTE=gdrive:inventory-control-backups

# Offsite backup sync interval (used by the offsite-backup service)
SYNC_INTERVAL=12h

# Nuvemshop store integration
STORE_NAME=My Nuvemshop
STORE_ENABLED=true
STORE_PLATFORM=nuvemshop
STORE_ID=<YOUR_STORE_ID>
STORE_ACCESS_TOKEN=<YOUR_ACCESS_TOKEN>
STORE_SYNC_INTERVAL_MINUTES=15

# REST API key (Admin role)
API_KEY=<YOUR_API_KEY>
