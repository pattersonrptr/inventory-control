@model StockMovement
@{
    ViewData["Title"] = "Registrar Entrada";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-arrow-down-circle"></i> Registrar Entrada de Estoque</h4>
            </div>
            <div class="card-body">
                <form asp-action="Entry" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="ProductId" class="form-label fw-semibold">Produto</label>
                        <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-select">
                            <option value="">— Selecione um produto —</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Quantity" class="form-label fw-semibold"></label>
                            <input asp-for="Quantity" class="form-control" min="1" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Date" class="form-label fw-semibold"></label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupplierId" class="form-label fw-semibold">Fornecedor (para esta entrada)</label>
                        <select asp-for="SupplierId" asp-items="ViewBag.SupplierId" class="form-select">
                            <option value="">— Selecione um fornecedor —</option>
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UnitCost" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input asp-for="UnitCost" class="form-control" step="0.01" placeholder="0,00" />
                        </div>
                        <span asp-validation-for="UnitCost" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"
                                  placeholder="Número da nota fiscal, lote, etc."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Registrar Entrada
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
