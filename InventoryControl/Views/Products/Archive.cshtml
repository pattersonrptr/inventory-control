@model Product
@{
    ViewData["Title"] = "Arquivar Produto";
    var hasMappings = Model.ExternalMappings.Any();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-warning">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="bi bi-archive"></i> Confirmar Arquivamento</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Tem certeza que deseja arquivar o produto <strong>@Model.Name</strong>?
                </div>

                <p>Ao arquivar:</p>
                <ul>
                    <li>O produto será ocultado das listagens, busca e relatórios padrão.</li>
                    <li>Não será possível registrar novas movimentações de estoque para ele.</li>
                    <li>O histórico (movimentações, custos, vendas) será preservado.</li>
                    @if (hasMappings)
                    {
                        <li>O produto será <strong>despublicado</strong> nas lojas integradas:
                            <strong>@string.Join(", ", Model.ExternalMappings.Select(m => m.StoreName))</strong>.</li>
                    }
                    <li>Você poderá reativá-lo a qualquer momento.</li>
                </ul>

                <dl class="row">
                    <dt class="col-sm-4">Nome</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    <dt class="col-sm-4">Categoria</dt>
                    <dd class="col-sm-8">@Model.Category?.Name</dd>
                    <dt class="col-sm-4">Estoque Atual</dt>
                    <dd class="col-sm-8">@Model.CurrentStock</dd>
                </dl>

                <form asp-action="Archive" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-archive"></i> Confirmar Arquivamento
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
