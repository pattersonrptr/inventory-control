@model Product
@{
    ViewData["Title"] = "Novo Produto";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Novo Produto</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Nome do produto" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"
                                  placeholder="Descrição opcional..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CostPrice" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="CostPrice" class="form-control" step="0.01" placeholder="0,00" />
                            </div>
                            <span asp-validation-for="CostPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SellingPrice" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="SellingPrice" class="form-control" step="0.01" placeholder="0,00" />
                            </div>
                            <span asp-validation-for="SellingPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="MinimumStock" class="form-label fw-semibold"></label>
                            <input asp-for="MinimumStock" class="form-control" min="0" />
                            <span asp-validation-for="MinimumStock" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Sku" class="form-label fw-semibold"></label>
                            <input asp-for="Sku" class="form-control" placeholder="Ex.: PROD-001" />
                            <span asp-validation-for="Sku" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Brand" class="form-label fw-semibold"></label>
                            <input asp-for="Brand" class="form-control" placeholder="Ex.: BRW, MOLIN..." />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold">Categoria</label>
                            <div class="input-group">
                                <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
                                    <option value="">— Selecione —</option>
                                </select>
                                <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#categoryModal" title="Nova Categoria">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold"><i class="bi bi-images"></i> Imagens do Produto</label>
                        <input type="file" class="form-control" name="images" accept="image/*" multiple />
                        <div class="form-text">Formatos aceitos: JPG, PNG, GIF, WebP. Selecione vários de uma vez.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Salvar
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_CategoryModal")

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/inline-create.js"></script>
}
