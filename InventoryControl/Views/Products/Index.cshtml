@model PagedResult<Product>
@{
    ViewData["Title"] = "Produtos";
    var showArchived = ViewBag.ShowArchived == true;
    var pendingSync = ViewBag.PendingSyncCount as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><i class="bi bi-box-seam"></i> Produtos</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-showArchived="@(!showArchived)"
           class="btn @(showArchived ? "btn-secondary" : "btn-outline-secondary")">
            <i class="bi @(showArchived ? "bi-eye-slash" : "bi-archive")"></i>
            @(showArchived ? "Ocultar arquivados" : "Mostrar arquivados")
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Novo Produto
        </a>
    </div>
</div>

@if (pendingSync > 0)
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-cloud-slash"></i>
            <strong>@pendingSync produto(s)</strong> com status fora de sincronia com a loja externa.
            Será tentado novamente em segundo plano.
        </div>
        <form asp-action="ResyncPending" method="post" class="m-0">
            <button type="submit" class="btn btn-sm btn-warning">
                <i class="bi bi-arrow-clockwise"></i> Re-sincronizar agora
            </button>
        </form>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 50px;"></th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Marca</th>
                    <th class="text-end">Preço de Custo</th>
                    <th class="text-end">Preço de Venda</th>
                    <th class="text-center">Estoque</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var hasPendingSync = item.ExternalMappings.Any(m => m.SyncStatus != ExternalSyncStatus.Synced);
                    var conflictMapping = item.ExternalMappings.FirstOrDefault(m => m.HasConflict);
                    <tr class="@(item.IsArchived ? "table-secondary text-muted" : item.IsBelowMinimumStock ? "table-warning" : "")">
                        <td>
                            @if (item.PrimaryImagePath is not null)
                            {
                                <img src="@item.PrimaryImagePath" alt="@item.Name" class="rounded" style="width: 40px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <span class="text-muted"><i class="bi bi-image" style="font-size: 1.5rem;"></i></span>
                            }
                        </td>
                        <td class="fw-semibold">
                            @item.Name
                            @if (item.IsArchived)
                            {
                                <span class="badge bg-secondary ms-1" title="Arquivado">
                                    <i class="bi bi-archive-fill"></i> Arquivado
                                </span>
                            }
                            else if (item.IsBelowMinimumStock)
                            {
                                <span class="badge bg-danger ms-1" title="Abaixo do estoque mínimo">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                </span>
                            }
                            @if (hasPendingSync)
                            {
                                <span class="badge bg-warning text-dark ms-1" title="Sincronização com loja pendente">
                                    <i class="bi bi-cloud-slash"></i>
                                </span>
                            }
                            @if (conflictMapping is not null)
                            {
                                <span class="badge bg-info text-dark ms-1" title="Divergente da loja: @conflictMapping.ConflictDetails">
                                    <i class="bi bi-exclamation-diamond"></i> Divergente
                                </span>
                            }
                        </td>
                        <td class="text-muted">@item.Category?.FullName</td>
                        <td class="text-muted">@(item.Brand ?? "—")</td>
                        <td class="text-end">@item.CostPrice.ToString("C")</td>
                        <td class="text-end">@item.SellingPrice.ToString("C")</td>
                        <td class="text-center fw-bold @(!item.IsArchived && item.IsBelowMinimumStock ? "text-danger" : "")">
                            @item.CurrentStock
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary" title="Detalhes">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (item.IsArchived)
                            {
                                <a asp-action="Unarchive" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-success" title="Reativar">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                </a>
                            }
                            else
                            {
                                <a asp-action="Archive" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-warning" title="Arquivar">
                                    <i class="bi bi-archive"></i>
                                </a>
                            }
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </a>
                            @if (ViewBag.IntegrationEnabled == true && !item.IsArchived && !item.ExternalMappings.Any())
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        title="Enviar para Loja"
                                        onclick="pushProduct(@item.Id, this)">
                                    <i class="bi bi-cloud-upload"></i>
                                </button>
                            }
                            @if (ViewBag.IntegrationEnabled == true && !item.IsArchived && item.ExternalMappings.Any())
                            {
                                <button class="btn btn-sm btn-outline-info"
                                        title="Enviar imagens para loja"
                                        onclick="pushImages(@item.Id, this)">
                                    <i class="bi bi-images"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            Nenhum produto cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_Pagination", (object)Model)

@if (ViewBag.IntegrationEnabled == true)
{
    <div id="pushToast" class="toast align-items-center border-0 position-fixed bottom-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true" style="z-index:1100">
        <div class="d-flex">
            <div id="pushToastBody" class="toast-body fw-semibold"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
        </div>
    </div>

    <script>
        async function pushProduct(productId, btn) {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
            try {
                const res = await fetch(`/api/sync/push-product/${productId}`, { method: 'POST' });
                const data = await res.json();
                showPushToast(res.ok, data.message ?? (res.ok ? 'Enviado.' : 'Falhou.'));
                if (res.ok) btn.closest('tr').querySelector('.btn-outline-success')?.remove();
            } catch (e) {
                showPushToast(false, 'Falha na requisição: ' + e.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-cloud-upload"></i>';
            }
        }

        async function pushImages(productId, btn) {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
            try {
                const res = await fetch(`/api/sync/push-images/${productId}`, { method: 'POST' });
                const data = await res.json();
                showPushToast(res.ok, data.message ?? (res.ok ? 'Enviado.' : 'Falhou.'));
            } catch (e) {
                showPushToast(false, 'Falha na requisição: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-images"></i>';
            }
        }

        function showPushToast(success, message) {
            const toastEl = document.getElementById('pushToast');
            const toastBody = document.getElementById('pushToastBody');
            toastEl.classList.remove('bg-success', 'bg-danger', 'text-white');
            toastEl.classList.add(success ? 'bg-success' : 'bg-danger', 'text-white');
            toastBody.textContent = message;
            bootstrap.Toast.getOrCreateInstance(toastEl).show();
        }
    </script>
}
