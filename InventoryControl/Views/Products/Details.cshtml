@model Product
@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="bi bi-box"></i> @Model.Name</h4>
                @if (Model.IsBelowMinimumStock)
                {
                    <span class="badge bg-danger fs-6">
                        <i class="bi bi-exclamation-triangle-fill"></i> Abaixo do Estoque Mínimo
                    </span>
                }
            </div>
            <div class="card-body">
                @if (Model.Images.Any())
                {
                    <div class="text-center mb-3">
                        @if (Model.Images.Count == 1)
                        {
                            <img src="@Model.Images.First().ImagePath" alt="@(Model.Images.First().AltText ?? Model.Name)" class="img-fluid rounded" style="max-height: 250px;" />
                        }
                        else
                        {
                            <div id="productCarousel" class="carousel slide" data-bs-ride="carousel" style="max-width: 400px; margin: auto;">
                                <div class="carousel-indicators">
                                    @for (var i = 0; i < Model.Images.Count; i++)
                                    {
                                        <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="@i"
                                                class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
                                    }
                                </div>
                                <div class="carousel-inner">
                                    @{ var idx = 0; }
                                    @foreach (var img in Model.Images.OrderBy(i => i.DisplayOrder))
                                    {
                                        <div class="carousel-item @(idx == 0 ? "active" : "")">
                                            <img src="@img.ImagePath" class="d-block w-100 rounded" alt="@(img.AltText ?? Model.Name)" style="max-height: 300px; object-fit: contain;" />
                                        </div>
                                        idx++;
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            </div>
                        }
                    </div>
                }
                <dl class="row">
                    <dt class="col-sm-4">Descrição</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "—")</dd>

                    <dt class="col-sm-4">Categoria</dt>
                    <dd class="col-sm-8">@Model.Category?.FullName</dd>

                    @if (!string.IsNullOrEmpty(Model.Brand))
                    {
                        <dt class="col-sm-4">Marca</dt>
                        <dd class="col-sm-8">@Model.Brand</dd>
                    }

                    <dt class="col-sm-4">Preço de Custo</dt>
                    <dd class="col-sm-8">@Model.CostPrice.ToString("C")</dd>

                    <dt class="col-sm-4">Preço de Venda</dt>
                    <dd class="col-sm-8">@Model.SellingPrice.ToString("C")</dd>

                    <dt class="col-sm-4">Estoque Atual</dt>
                    <dd class="col-sm-8 fw-bold @(Model.IsBelowMinimumStock ? "text-danger" : "")">
                        @Model.CurrentStock unidades
                    </dd>

                    <dt class="col-sm-4">Estoque Mínimo</dt>
                    <dd class="col-sm-8">@Model.MinimumStock unidades</dd>

                    @if (Model.Sku is not null)
                    {
                        <dt class="col-sm-4">SKU</dt>
                        <dd class="col-sm-8">@Model.Sku</dd>
                    }

                    @if (Model.ExternalMappings.Any())
                    {
                        <dt class="col-sm-4">IDs Externos</dt>
                        <dd class="col-sm-8">
                            @foreach (var mapping in Model.ExternalMappings)
                            {
                                <span class="badge bg-info me-1">@mapping.StoreName: @mapping.ExternalId</span>
                            }
                        </dd>
                    }
                </dl>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Voltar à Lista
                    </a>
                </div>
            </div>
        </div>

        @if (Model.StockMovements.Any())
        {
            <div class="card mt-4">
                <div class="card-header fw-bold">
                    <i class="bi bi-clock-history"></i> Histórico de Movimentações
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Data</th>
                                <th>Tipo</th>
                                <th class="text-end">Qtd</th>
                                <th>Observações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in Model.StockMovements.OrderByDescending(m => m.Date))
                            {
                                <tr>
                                    <td>@mov.Date.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (mov.Type == MovementType.Entry)
                                        {
                                            <span class="badge bg-success">Entrada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Saída</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">@mov.Quantity</td>
                                    <td class="text-muted small">@(mov.Notes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
