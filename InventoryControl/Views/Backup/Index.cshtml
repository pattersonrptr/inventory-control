@using InventoryControl.ViewModels
@model BackupViewModel
@{
    ViewData["Title"] = "Backup do Banco de Dados";
}

<h2 class="mb-4"><i class="bi bi-database-down"></i> Backup do Banco de Dados</h2>

<div class="row g-4">

    @* ── Download local ──────────────────────────────────────────────── *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-download"></i> Download Imediato
            </div>
            <div class="card-body d-flex flex-column">
                <p class="card-text">
                    Gera um backup completo e envia diretamente para o seu navegador.
                    Cada download é registrado no log de auditoria.
                </p>
                <form asp-action="Download" method="post" class="mt-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-download"></i> Baixar Backup Agora
                    </button>
                </form>
            </div>
        </div>
    </div>

    @* ── Upload para Google Cloud ───────────────────────────────────── *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-cloud-upload"></i> Enviar para Google Drive</span>
                @if (Model.IsRcloneConfigured)
                {
                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Configurado</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle"></i> Não configurado</span>
                }
            </div>
            <div class="card-body d-flex flex-column">
                @if (Model.IsRcloneConfigured)
                {
                    <p class="card-text">
                        Gera o backup e envia diretamente para
                        <code>@Model.RemotePath</code> via rclone.<br />
                        <small class="text-muted">Remotos configurados: <strong>@Model.ConfiguredRemotes</strong></small>
                    </p>
                    <form asp-action="UploadToCloud" method="post" class="mt-auto">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-upload"></i> Enviar para Google Drive
                        </button>
                    </form>
                }
                else
                {
                    <p class="card-text text-muted">
                        O rclone não está configurado. Siga os passos abaixo para habilitar o upload para o Google Drive.
                    </p>
                    <div class="alert alert-info mb-0 mt-auto small">
                        <strong><i class="bi bi-info-circle"></i> Como configurar:</strong>
                        <ol class="mb-0 mt-2">
                            <li>
                                Execute no terminal do servidor:<br />
                                <code>docker exec -it inventory-offsite-backup rclone config --config /config/rclone/rclone.conf</code>
                            </li>
                            <li>Escolha <strong>n</strong> (new remote) → nome: <code>gdrive</code> → tipo: <code>drive</code></li>
                            <li>Siga o fluxo OAuth2: uma URL será exibida → abra no browser → autorize → cole o token de volta</li>
                            <li>
                                Certifique-se de que o arquivo de configuração é legível pelo container da aplicação:<br />
                                <code>chmod o+r /caminho/para/rclone.conf</code>
                            </li>
                            <li>Reinicie a aplicação ou aguarde — o status será atualizado automaticamente.</li>
                        </ol>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<div class="card mt-4 border-0 bg-light">
    <div class="card-body">
        <h6 class="card-title"><i class="bi bi-info-circle text-info"></i> Informações</h6>
        <ul class="mb-0 small">
            <li><strong>PostgreSQL:</strong> gera um arquivo <code>.sql</code> via <code>pg_dump</code>.</li>
            <li><strong>SQLite:</strong> copia o arquivo <code>.db</code> diretamente.</li>
            <li>Backups automáticos são realizados a cada 12 horas pelo serviço de backup dedicado e sincronizados para o Google Drive.</li>
            <li>Cada operação (download ou upload) é registrada no <a asp-controller="AuditLogs" asp-action="Index">log de auditoria</a>.</li>
            <li>Destino configurado: <code>@(string.IsNullOrEmpty(Model.RemotePath) ? "não definido" : Model.RemotePath)</code>
                — altere via variável de ambiente <code>OffsiteBackup__RemotePath</code>.</li>
        </ul>
    </div>
</div>

