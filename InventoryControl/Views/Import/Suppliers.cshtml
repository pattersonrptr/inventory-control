@using InventoryControl.Features.Products
@{
    ViewData["Title"] = "Importar Fornecedores";
    var result = ViewBag.Result as CsvImportResult<Supplier>;
}

<h1 class="mb-4"><i class="bi bi-upload"></i> Importar Fornecedores via CSV</h1>

<div class="row">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-file-earmark-arrow-up"></i> Enviar Arquivo</div>
            <div class="card-body">
                <form asp-action="PreviewSuppliers" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="file" class="form-label fw-semibold">Arquivo CSV</label>
                        <input type="file" class="form-control" id="file" name="file" accept=".csv,.txt" required />
                        <div class="form-text">Separador aceito: vírgula (,) ou ponto e vírgula (;)</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-eye"></i> Visualizar
                    </button>
                </form>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle"></i> Formato Esperado</div>
            <div class="card-body">
                <p class="mb-2">Colunas aceitas (cabeçalho na primeira linha):</p>
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light">
                        <tr><th>Coluna</th><th>Obrigatória</th><th>Exemplo</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Nome / Name</td><td><span class="badge bg-danger">Sim</span></td><td>PetBrasil LTDA</td></tr>
                        <tr><td>CNPJ</td><td>Não</td><td>12.345.678/0001-90</td></tr>
                        <tr><td>Telefone / Phone</td><td>Não</td><td>(11) 99999-0000</td></tr>
                        <tr><td>E-mail / Email</td><td>Não</td><td>contato@petbrasil.com</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (result is not null)
    {
        <div class="col-lg-6">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-table"></i> Pré-visualização</span>
                    <span>
                        <span class="badge bg-success">@result.ValidItems.Count válidos</span>
                        <span class="badge bg-danger">@result.Errors.Count erros</span>
                    </span>
                </div>
                <div class="card-body p-0">
                    @if (result.Errors.Any())
                    {
                        <div class="alert alert-warning m-3 mb-0">
                            <strong>Erros encontrados:</strong>
                            <ul class="mb-0 mt-1">
                                @foreach (var err in result.Errors)
                                {
                                    <li>Linha @err.Row: @err.Message</li>
                                }
                            </ul>
                        </div>
                    }
                    @if (result.ValidItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Nome</th>
                                        <th>CNPJ</th>
                                        <th>Telefone</th>
                                        <th>E-mail</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in result.ValidItems)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.Cnpj</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Email</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer">
                            <form asp-action="ConfirmSuppliers" method="post">
                                <input type="hidden" name="suppliersJson"
                                       value="@System.Text.Json.JsonSerializer.Serialize(result.ValidItems)" />
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle"></i> Confirmar Importação (@result.ValidItems.Count fornecedores)
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
