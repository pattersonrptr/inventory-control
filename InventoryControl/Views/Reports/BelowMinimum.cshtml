@model IEnumerable<Product>
@{
    ViewData["Title"] = "Produtos Abaixo do Estoque Mínimo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">
        <i class="bi bi-exclamation-triangle text-warning"></i> Produtos Abaixo do Estoque Mínimo
    </h1>
    <span class="badge bg-danger fs-6">@Model.Count() produto(s)</span>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        <strong>Tudo certo!</strong> Nenhum produto está abaixo do estoque mínimo no momento.
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Os produtos abaixo precisam de reposição. Entre em contato com os fornecedores correspondentes.
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th class="text-center">Estoque Atual</th>
                        <th class="text-center">Estoque Mínimo</th>
                        <th class="text-center">Déficit</th>
                        <th class="text-end">Ação</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var deficit = item.MinimumStock - item.CurrentStock;
                        <tr class="table-danger">
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-muted">@item.Category?.Name</td>
                            <td class="text-center fw-bold text-danger">@item.CurrentStock</td>
                            <td class="text-center">@item.MinimumStock</td>
                            <td class="text-center">
                                <span class="badge bg-danger">-@deficit</span>
                            </td>
                            <td class="text-end">
                                <a asp-controller="StockMovements" asp-action="Entry"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-arrow-down-circle"></i> Registrar Entrada
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
