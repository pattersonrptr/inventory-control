@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0"><i class="bi bi-speedometer2"></i> Dashboard</h1>
    <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</small>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-box-seam fs-1"></i>
                <div>
                    <div class="card-title small mb-0 text-white-50">Total Products</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalProducts</div>
                </div>
            </div>
            <div class="card-footer bg-primary border-0">
                <a asp-controller="Products" asp-action="Index" class="text-white text-decoration-none small">
                    View all <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white h-100 @(ViewBag.ProductsBelowMinimum > 0 ? "bg-danger" : "bg-success")">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-triangle fs-1"></i>
                <div>
                    <div class="card-title small mb-0 text-white-50">Below Minimum</div>
                    <div class="display-6 fw-bold">@ViewBag.ProductsBelowMinimum</div>
                </div>
            </div>
            <div class="card-footer border-0 @(ViewBag.ProductsBelowMinimum > 0 ? "bg-danger" : "bg-success")">
                <a asp-controller="Reports" asp-action="BelowMinimum" class="text-white text-decoration-none small">
                    View list <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-info h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-arrow-left-right fs-1"></i>
                <div>
                    <div class="card-title small mb-0 text-white-50">Stock Movements</div>
                    <div class="fw-bold mt-1">Record entry or exit</div>
                </div>
            </div>
            <div class="card-footer bg-info border-0 d-flex gap-3">
                <a asp-controller="StockMovements" asp-action="Entry" class="text-white text-decoration-none small">
                    <i class="bi bi-arrow-down-circle"></i> Entry
                </a>
                <a asp-controller="StockMovements" asp-action="Exit" class="text-white text-decoration-none small">
                    <i class="bi bi-arrow-up-circle"></i> Exit
                </a>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.IntegrationEnabled == true)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-cloud-arrow-up"></i> Store Integration</h5>
        </div>
        <div class="card-body d-flex gap-3 flex-wrap">
            <button id="btnSyncOrders" class="btn btn-primary" onclick="syncOrders()">
                <span id="spinnerOrders" class="spinner-border spinner-border-sm d-none" role="status"></span>
                <i class="bi bi-bag-check" id="iconOrders"></i>
                Sync Orders
            </button>
            <button id="btnSyncProducts" class="btn btn-secondary" onclick="syncProducts()">
                <span id="spinnerProducts" class="spinner-border spinner-border-sm d-none" role="status"></span>
                <i class="bi bi-arrow-repeat" id="iconProducts"></i>
                Sync Products
            </button>
            <button id="btnSyncCategories" class="btn btn-outline-secondary" onclick="syncCategories()">
                <span id="spinnerCategories" class="spinner-border spinner-border-sm d-none" role="status"></span>
                <i class="bi bi-tags" id="iconCategories"></i>
                Sync Categories
            </button>
        </div>
    </div>

    <div id="syncToast" class="toast align-items-center border-0 position-fixed bottom-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true" style="z-index:1100">
        <div class="d-flex">
            <div id="syncToastBody" class="toast-body fw-semibold"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>

    <script>
        async function callSync(url, btnId, spinnerId, iconId) {
            const btn = document.getElementById(btnId);
            const spinner = document.getElementById(spinnerId);
            const icon = document.getElementById(iconId);
            btn.disabled = true;
            spinner.classList.remove('d-none');
            icon.classList.add('d-none');
            try {
                const res = await fetch(url, { method: 'POST' });
                const data = await res.json();
                showToast(res.ok, data.message ?? (res.ok ? 'Done.' : 'Failed.'));
            } catch (e) {
                showToast(false, 'Request failed: ' + e.message);
            } finally {
                btn.disabled = false;
                spinner.classList.add('d-none');
                icon.classList.remove('d-none');
            }
        }

        function syncOrders() {
            callSync('/api/sync/orders', 'btnSyncOrders', 'spinnerOrders', 'iconOrders');
        }

        function syncProducts() {
            callSync('/api/sync/products', 'btnSyncProducts', 'spinnerProducts', 'iconProducts');
        }

        function syncCategories() {
            callSync('/api/sync/categories', 'btnSyncCategories', 'spinnerCategories', 'iconCategories');
        }

        function showToast(success, message) {
            const toastEl = document.getElementById('syncToast');
            const toastBody = document.getElementById('syncToastBody');
            toastEl.classList.remove('bg-success', 'bg-danger', 'text-white');
            toastEl.classList.add(success ? 'bg-success' : 'bg-danger', 'text-white');
            toastBody.textContent = message;
            bootstrap.Toast.getOrCreateInstance(toastEl).show();
        }
    </script>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Movements</h5>
        <a asp-controller="StockMovements" asp-action="Index" class="btn btn-sm btn-outline-secondary">
            View all
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th class="text-end">Quantity</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var recentMovements = ViewBag.RecentMovements as List<ControleEstoque.Models.StockMovement>;
                }
                @if (recentMovements is not null && recentMovements.Any())
                {
                    foreach (var mov in recentMovements)
                    {
                        <tr>
                            <td>@mov.Date.ToString("MM/dd/yyyy")</td>
                            <td>@mov.Product?.Name</td>
                            <td>
                                @if (mov.Type == ControleEstoque.Models.MovementType.Entry)
                                {
                                    <span class="badge bg-success"><i class="bi bi-arrow-down-circle"></i> Entry</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-arrow-up-circle"></i> Exit</span>
                                }
                            </td>
                            <td class="text-end fw-bold">@mov.Quantity</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No stock movements recorded yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
