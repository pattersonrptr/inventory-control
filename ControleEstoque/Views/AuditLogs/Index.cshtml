@model IEnumerable<ControleEstoque.Models.AuditLog>
@{
    ViewData["Title"] = "Histórico de Auditoria";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history"></i> Histórico de Auditoria</h2>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Data/Hora</th>
                <th>Usuário</th>
                <th>Ação</th>
                <th>Entidade</th>
                <th>ID</th>
                <th>Detalhes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@log.UserName</td>
                    <td>
                        @switch (log.Action)
                        {
                            case "Created":
                                <span class="badge bg-success">Criado</span>
                                break;
                            case "Updated":
                                <span class="badge bg-warning text-dark">Atualizado</span>
                                break;
                            case "Deleted":
                                <span class="badge bg-danger">Excluído</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@log.Action</span>
                                break;
                        }
                    </td>
                    <td>@log.EntityName</td>
                    <td>@log.EntityId</td>
                    <td>
                        @if (log.OldValues != null || log.NewValues != null)
                        {
                            <button class="btn btn-sm btn-outline-info" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#detail-@log.Id">
                                <i class="bi bi-eye"></i>
                            </button>
                        }
                    </td>
                </tr>
                @if (log.OldValues != null || log.NewValues != null)
                {
                    <tr class="collapse" id="detail-@log.Id">
                        <td colspan="6">
                            <div class="row">
                                @if (log.OldValues != null)
                                {
                                    <div class="col-md-6">
                                        <strong class="text-danger">Valores Anteriores:</strong>
                                        <pre class="bg-light p-2 rounded small">@log.OldValues</pre>
                                    </div>
                                }
                                @if (log.NewValues != null)
                                {
                                    <div class="col-md-6">
                                        <strong class="text-success">Valores Novos:</strong>
                                        <pre class="bg-light p-2 rounded small">@log.NewValues</pre>
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
