@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products Below Minimum Stock";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">
        <i class="bi bi-exclamation-triangle text-warning"></i> Products Below Minimum Stock
    </h1>
    <span class="badge bg-danger fs-6">@Model.Count() product(s)</span>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        <strong>All good!</strong> No products are below the minimum stock level at this time.
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        The products below need restocking. Please contact the corresponding suppliers.
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th class="text-center">Current Stock</th>
                        <th class="text-center">Minimum Stock</th>
                        <th class="text-center">Deficit</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var deficit = item.MinimumStock - item.CurrentStock;
                        <tr class="table-danger">
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-muted">@item.Category?.Name</td>
                            <td class="text-muted">@item.Supplier?.Name</td>
                            <td class="text-center fw-bold text-danger">@item.CurrentStock</td>
                            <td class="text-center">@item.MinimumStock</td>
                            <td class="text-center">
                                <span class="badge bg-danger">-@deficit</span>
                            </td>
                            <td class="text-end">
                                <a asp-controller="StockMovements" asp-action="Entry"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-arrow-down-circle"></i> Record Entry
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
