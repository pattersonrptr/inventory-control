@model Product
@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="bi bi-box"></i> @Model.Name</h4>
                @if (Model.IsBelowMinimumStock)
                {
                    <span class="badge bg-danger fs-6">
                        <i class="bi bi-exclamation-triangle-fill"></i> Below Minimum Stock
                    </span>
                }
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "—")</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category?.Name</dd>

                    <dt class="col-sm-4">Supplier</dt>
                    <dd class="col-sm-8">@Model.Supplier?.Name</dd>

                    <dt class="col-sm-4">Cost Price</dt>
                    <dd class="col-sm-8">@Model.CostPrice.ToString("C")</dd>

                    <dt class="col-sm-4">Selling Price</dt>
                    <dd class="col-sm-8">@Model.SellingPrice.ToString("C")</dd>

                    <dt class="col-sm-4">Current Stock</dt>
                    <dd class="col-sm-8 fw-bold @(Model.IsBelowMinimumStock ? "text-danger" : "")">
                        @Model.CurrentStock units
                    </dd>

                    <dt class="col-sm-4">Minimum Stock</dt>
                    <dd class="col-sm-8">@Model.MinimumStock units</dd>

                    @if (!string.IsNullOrEmpty(Model.Sku))
                    {
                        <dt class="col-sm-4">SKU</dt>
                        <dd class="col-sm-8">@Model.Sku</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.ExternalId))
                    {
                        <dt class="col-sm-4">External ID</dt>
                        <dd class="col-sm-8">@Model.ExternalId (@Model.ExternalIdSource)</dd>
                    }
                </dl>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>

        @if (Model.StockMovements.Any())
        {
            <div class="card mt-4">
                <div class="card-header fw-bold">
                    <i class="bi bi-clock-history"></i> Movement History
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th class="text-end">Qty</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in Model.StockMovements.OrderByDescending(m => m.Date))
                            {
                                <tr>
                                    <td>@mov.Date.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        @if (mov.Type == MovementType.Entry)
                                        {
                                            <span class="badge bg-success">Entry</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Exit</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">@mov.Quantity</td>
                                    <td class="text-muted small">@(mov.Notes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
