@model dynamic

@{
    int page = (int)Model.Page;
    int totalPages = (int)Model.TotalPages;
    int totalCount = (int)Model.TotalCount;
    string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

@if (totalPages > 1)
{
    <nav aria-label="Paginação" class="mt-3">
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @totalCount registro(s) — Página @(page) de @totalPages
            </small>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="@controller" asp-action="@action" asp-route-page="@(page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @{
                    int startPage = Math.Max(1, page - 2);
                    int endPage = Math.Min(totalPages, page + 2);
                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-controller="@controller" asp-action="@action" asp-route-page="1">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" asp-controller="@controller" asp-action="@action" asp-route-page="@i">@i</a>
                        </li>
                    }
                    if (endPage < totalPages)
                    {
                        if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" asp-controller="@controller" asp-action="@action" asp-route-page="@totalPages">@totalPages</a>
                        </li>
                    }
                }
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-controller="@controller" asp-action="@action" asp-route-page="@(page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    </nav>
}
